{
  "name": "fastapi-full-stack-template",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "bun run --filter frontend dev",
    "desktop:backend:build": "pyinstaller --distpath src-tauri/binaries sparkbot-backend.spec",
    "desktop:frontend:build": "node scripts/run-desktop-frontend.mjs build",
    "desktop:frontend:dev": "node scripts/run-desktop-frontend.mjs dev",
    "desktop:tauri:build": "cargo tauri build --config src-tauri/tauri.conf.json",
    "desktop:tauri:dev": "cargo tauri dev --config src-tauri/tauri.conf.json",
    "lint": "bun run --filter frontend lint",
    "test": "bun run --filter frontend test",
    "test:ui": "bun run --filter frontend test:ui"
  }
}

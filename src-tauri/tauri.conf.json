{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Sparkbot Local",
    "version":  "1.6.56",
    "identifier":  "com.sparkpitlabs.sparkbot.local",
    "build":  {
                  "beforeBuildCommand":  "bun run desktop:frontend:build",
                  "beforeDevCommand":  "bun run desktop:frontend:dev",
                  "devUrl":  "http://127.0.0.1:5173",
                  "frontendDist":  "../frontend/dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "Sparkbot Local",
                                    "width":  1440,
                                    "height":  960,
                                    "minWidth":  1100,
                                    "minHeight":  760,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/512x512.png",
                                "icons/icon.ico"
                            ],
                   "externalBin":  [
                                       "binaries/sparkbot-backend"
                                   ],
                   "windows":  {
                                   "nsis":  {
                                                "installerHooks":  "nsis/installer-hooks.nsh"
                                            }
                               }
               }
}

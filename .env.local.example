# Sparkbot local Docker environment template.
# Normal installs should run:
#   bash scripts/sparkbot-start.sh
# The setup wizard creates .env.local from this file and writes provider keys.
# Advanced users may still edit .env.local directly.

# Core app identity
PROJECT_NAME=Sparkbot
# Local-only default. `scripts/sparkbot-start.sh --server` replaces this with
# a prompted private passphrase before binding Sparkbot to 0.0.0.0.
SPARKBOT_PASSPHRASE=sparkbot-local

# Optional: set this if you want a stable local auth secret across container
# rebuilds. If left blank, quickstart scripts generate one at launch.
# SECRET_KEY=REPLACE_WITH_RANDOM_64_HEX

# Local Docker database defaults. The setup wizard writes these if missing.
DATABASE_TYPE=postgresql
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=sparkbot
POSTGRES_USER=sparkbot
POSTGRES_PASSWORD=sparkbot-local
SPARKBOT_FRONTEND_PORT=3000
SPARKBOT_FRONTEND_BIND_HOST=127.0.0.1

# Personal mode is the safest default for a fresh local install.
SPARKBOT_GUARDIAN_POLICY_ENABLED=true
WORKSTATION_LIVE_TERMINAL_ENABLED=false

# Set by scripts/sparkbot-setup.sh. Leave blank in the template.
OPENAI_API_KEY=
OPENAI_AUTH_MODE=api_key
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=

# Optional routing defaults. For ChatGPT-plan Codex subscription routing, run
# `codex login`, then use openai_codex + openai-codex/gpt-5.3-codex and set
# OPENAI_AUTH_MODE=codex_sub.
SPARKBOT_DEFAULT_PROVIDER=openai
SPARKBOT_MODEL=gpt-5-mini
SPARKBOT_BACKUP_MODEL_1=claude-sonnet-4-5
SPARKBOT_BACKUP_MODEL_2=gemini/gemini-2.0-flash
SPARKBOT_HEAVY_HITTER_MODEL=gpt-5-mini
SPARKBOT_LOCAL_MODEL=
OLLAMA_API_BASE=http://host.docker.internal:11434
SPARKBOT_DEFAULT_CROSS_PROVIDER_FALLBACK=true
SPARKBOT_TOKEN_GUARDIAN_MODE=shadow

# Optional integrations
TELEGRAM_BOT_TOKEN=
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_SHARED_DRIVE_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REFRESH_TOKEN=
GITHUB_TOKEN=
GITHUB_SSH_KEY_PATH=
GITHUB_SSH_PRIVATE_KEY=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_DEFAULT_REPO=
GITHUB_ALLOWED_REPOS=

# Optional ChatGPT-plan Codex subscription routing. Run `codex login`, choose
# ChatGPT sign-in, finish browser auth, then restart Sparkbot.
# SPARKBOT_DEFAULT_PROVIDER=openai_codex
# SPARKBOT_MODEL=openai-codex/gpt-5.3-codex
# SPARKBOT_CODEX_SUBSCRIPTION_MODEL=gpt-5.3-codex
# CODEX_HOME=%USERPROFILE%\.codex
# SPARKBOT_CODEX_CLI=%APPDATA%\npm\codex.ps1
# SPARKBOT_CODEX_CLI_TIMEOUT_SECONDS=7200

# Keep useful browser, Telegram, Discord, and meeting chat turns available
# through per-user shared work memory.
SPARKBOT_UNIFIED_CHAT_MEMORY_ENABLED=true

# Optional LIMA Robotics OS bridge; leave blank for replay/simulation-only demos.
# LIMA Robotics OS MCP bridge. Example: http://127.0.0.1:9990/mcp
LIMA_MCP_URL=
LIMA_DAEMON_URL=

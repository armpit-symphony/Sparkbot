# Sparkbot local Docker environment template.
# Normal installs should run:
#   bash scripts/sparkbot-start.sh
# The setup wizard creates .env.local from this file and writes provider keys.
# Advanced users may still edit .env.local directly.

# Core app identity
PROJECT_NAME=Sparkbot
# Local-only default. `scripts/sparkbot-start.sh --server` refuses this value
# and forces a private passphrase before binding Sparkbot to 0.0.0.0.
SPARKBOT_PASSPHRASE=sparkbot-local

# Optional: set this if you want a stable local auth secret across container
# rebuilds. If left blank, quickstart scripts generate one at launch.
# SECRET_KEY=REPLACE_WITH_RANDOM_64_HEX

# Local Docker database defaults. The setup wizard writes these if missing.
DATABASE_TYPE=postgresql
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=sparkbot
POSTGRES_USER=sparkbot
POSTGRES_PASSWORD=sparkbot-local
SPARKBOT_FRONTEND_PORT=3000
SPARKBOT_FRONTEND_BIND_HOST=127.0.0.1

# Personal mode is the safest default for a fresh local install.
SPARKBOT_GUARDIAN_POLICY_ENABLED=true

# Set by scripts/sparkbot-setup.sh. Leave blank in the template.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=

# Optional routing defaults
SPARKBOT_DEFAULT_PROVIDER=openai
SPARKBOT_MODEL=gpt-5-mini
SPARKBOT_BACKUP_MODEL_1=claude-sonnet-4-5
SPARKBOT_BACKUP_MODEL_2=gemini/gemini-2.0-flash
SPARKBOT_HEAVY_HITTER_MODEL=gpt-5-mini
SPARKBOT_LOCAL_MODEL=
OLLAMA_API_BASE=http://host.docker.internal:11434
SPARKBOT_DEFAULT_CROSS_PROVIDER_FALLBACK=true
SPARKBOT_TOKEN_GUARDIAN_MODE=shadow

# Optional integrations
TELEGRAM_BOT_TOKEN=
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GITHUB_TOKEN=

# Optional LIMA Robotics OS bridge; leave blank for replay/simulation-only demos.
LIMA_MCP_URL=
LIMA_DAEMON_URL=

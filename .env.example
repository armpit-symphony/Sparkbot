# Sparkbot server / VPS environment template
# Copy this file to .env for non-Docker service installs and hosted deployments.
# For laptop / desktop Docker installs, use .env.local.example instead.
#
# The simple systemd profile checked into this repo expects:
#   - repo root .env at /home/youruser/sparkbot-v2/.env
#   - backend working directory /home/youruser/sparkbot-v2/backend
#   - uvicorn bound to 127.0.0.1:8091 behind nginx or another reverse proxy

# ===================
# Core app identity
# ===================
PROJECT_NAME=Sparkbot
ENVIRONMENT=production
DOMAIN=chat.example.com
FRONTEND_HOST=https://chat.example.com
BACKEND_CORS_ORIGINS=https://chat.example.com

# ===================
# Core security
# ===================
# Generate a strong secret, for example:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_64_HEX
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD
SPARKBOT_PASSPHRASE=REPLACE_WITH_STRONG_PASSPHRASE

# Harden production-by-default options for fresh installs.
WORKSTATION_LIVE_TERMINAL_ENABLED=false
SPARKBOT_GUARDIAN_POLICY_ENABLED=false
SPARKBOT_SERVICE_USE_SUDO=false
SPARKBOT_ALLOWED_SERVICES=sparkbot-v2

# ===================
# Database
# ===================
# The simplest single-node install uses sqlite and matches the working server's
# lightweight layout. For PostgreSQL deployments, switch DATABASE_TYPE below and
# fill in the POSTGRES_* values.
DATABASE_TYPE=sqlite
SPARKBOT_DATA_DIR=/home/youruser/sparkbot-v2/backend/data

# DATABASE_TYPE=postgresql
# POSTGRES_SERVER=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=sparkbot
# POSTGRES_USER=sparkbot
# POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD

# ===================
# LLM provider keys
# ===================
# Set at least one provider key before expecting AI responses.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=
HF_API_KEY=
HUGGINGFACE_API_KEY=
EMERGENT_LLM_KEY=

# Optional default routing profile. These mirror the working server's shape more
# closely than the old monolithic template.
SPARKBOT_DEFAULT_PROVIDER=openai
SPARKBOT_MODEL=gpt-5-mini
SPARKBOT_BACKUP_MODEL_1=claude-sonnet-4-5
SPARKBOT_BACKUP_MODEL_2=gemini/gemini-2.0-flash
SPARKBOT_HEAVY_HITTER_MODEL=gpt-5-mini
SPARKBOT_LOCAL_MODEL=
SPARKBOT_DEFAULT_CROSS_PROVIDER_FALLBACK=true

# Token Guardian
SPARKBOT_TOKEN_GUARDIAN_MODE=live
SPARKBOT_TOKEN_GUARDIAN_LIVE_MODELS=gpt-5-mini,claude-sonnet-4-5,gemini/gemini-2.0-flash
SPARKBOT_TOKEN_GUARDIAN_SHADOW_ENABLED=true

# ===================
# Optional provider / bridge integrations
# ===================
# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_GMAIL_USER=me
GOOGLE_DRIVE_SHARED_DRIVE_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_ENABLED=true
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_REQUIRE_PRIVATE_CHAT=true
TELEGRAM_POLL_TIMEOUT_SECONDS=45
TELEGRAM_POLL_RETRY_SECONDS=5

# Discord
DISCORD_BOT_TOKEN=
DISCORD_ENABLED=false
DISCORD_DM_ONLY=false
DISCORD_GUILD_IDS=

# WhatsApp Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_WHATSAPP_VERIFY_TOKEN
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_ALLOWED_PHONES=
PUBLIC_URL=https://chat.example.com

# GitHub bridge / tools
GITHUB_BRIDGE_ENABLED=false
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_BOT_LOGIN=sparkbot
GITHUB_DEFAULT_REPO=
GITHUB_ALLOWED_REPOS=

# ===================
# Guardian / vault hardening
# ===================
SPARKBOT_EXECUTIVE_GUARDIAN_ENABLED=true
SPARKBOT_TASK_GUARDIAN_ENABLED=true
SPARKBOT_TASK_GUARDIAN_POLL_SECONDS=60
SPARKBOT_TASK_GUARDIAN_MAX_OUTPUT=2000
SPARKBOT_GUARDIAN_DATA_DIR=/home/youruser/sparkbot-v2/backend/data/guardian

# Optional: restrict operator access. Leave blank for single-user open mode.
# SPARKBOT_OPERATOR_USERNAMES=your-username
# SPARKBOT_OPERATOR_TELEGRAM_CHAT_IDS=123456789

# Set a PIN for break-glass privileged mode:
#   python3 -c "from app.services.guardian.auth import create_pin_hash; print(create_pin_hash('your-pin'))"
# SPARKBOT_OPERATOR_PIN_HASH=pbkdf2$sha256$300000$<salt>$<dk>

# Vault encryption key:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SPARKBOT_VAULT_KEY=

# Break-glass session TTL in seconds (default 900).
# SPARKBOT_BREAKGLASS_TTL_SECONDS=900

# Memory Guardian
SPARKBOT_MEMORY_GUARDIAN_ENABLED=true
SPARKBOT_MEMORY_GUARDIAN_DATA_DIR=/home/youruser/sparkbot-v2/backend/data/memory_guardian
SPARKBOT_MEMORY_GUARDIAN_MAX_TOKENS=1200
SPARKBOT_MEMORY_GUARDIAN_RETRIEVE_LIMIT=6

# Voice defaults
SPARKBOT_TTS_VOICE=alloy
SPARKBOT_TTS_MODEL=tts-1

# Optional SSH / server-ops allowlists
SPARKBOT_SERVER_COMMAND_TIMEOUT_SECONDS=20
SPARKBOT_SSH_ALLOWED_HOSTS=
SPARKBOT_SSH_ALLOWED_SERVICES=
SPARKBOT_SSH_CONNECT_TIMEOUT_SECONDS=10
SPARKBOT_SSH_COMMAND_TIMEOUT_SECONDS=30

# Optional skill directory override
SPARKBOT_SKILLS_DIR=skills

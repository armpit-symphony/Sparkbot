# Sparkbot Environment Variables Template
# Copy this file to .env and fill in the values

# ===================
# Frontend (React)
# ===================
REACT_APP_BACKEND_URL=https://remote.sparkpitlabs.com

# ===================
# Backend (FastAPI - sparkbot-v2)
# ===================
# Domain & Environment
DOMAIN=remote.sparkpitlabs.com
FRONTEND_HOST=https://remote.sparkpitlabs.com
ENVIRONMENT=production

# Project
PROJECT_NAME=Sparkbot
STACK_NAME=sparkbot

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# CORS (comma-separated origins)
BACKEND_CORS_ORIGINS=https://remote.sparkpitlabs.com,http://localhost,http://localhost:5173

# Database (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAILS_FROM_EMAIL=noreply@sparkpitlabs.com
EMAILS_FROM_NAME=Sparkbot
SMTP_TLS=True
SMTP_SSL=False

# First Superuser (admin account)
FIRST_SUPERUSER=admin@sparkpitlabs.com
FIRST_SUPERUSER_PASSWORD=your-admin-password

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# ===================
# Chat Backend (sparkbot-v1)
# ===================
# MongoDB (required)
MONGO_URL=mongodb://localhost:27017
DB_NAME=sparkbot

# JWT for chat authentication
CHAT_JWT_SECRET=your-chat-jwt-secret-change-in-production

# Dashboard access token
DASHBOARD_TOKEN=your-dashboard-token

# Sparkbot Service Key
SPARKBOT_SERVICE_KEY=your-service-key

# LLM API Keys (optional - at least one required for AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
Z01_API_KEY=
HF_API_KEY=
HUGGINGFACE_API_KEY=
EMERGENT_LLM_KEY=

# Sparkbot Mode (balanced, fast, quality)
SPARKBOT_MODE=balanced

# Google Workspace (optional - Gmail + Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_GMAIL_USER=me
GOOGLE_DRIVE_SHARED_DRIVE_ID=

# Memory Guardian (optional)
SPARKBOT_MEMORY_GUARDIAN_ENABLED=true
SPARKBOT_MEMORY_GUARDIAN_DATA_DIR=
SPARKBOT_MEMORY_GUARDIAN_MAX_TOKENS=1200
SPARKBOT_MEMORY_GUARDIAN_RETRIEVE_LIMIT=6

# Token Guardian shadow routing (optional)
SPARKBOT_TOKEN_GUARDIAN_SHADOW_ENABLED=true

# Executive / Task Guardian (optional)
SPARKBOT_EXECUTIVE_GUARDIAN_ENABLED=true
SPARKBOT_TASK_GUARDIAN_ENABLED=true
SPARKBOT_TASK_GUARDIAN_POLL_SECONDS=60
SPARKBOT_TASK_GUARDIAN_MAX_OUTPUT=2000
SPARKBOT_GUARDIAN_DATA_DIR=

# Server operations (optional)
SPARKBOT_ALLOWED_SERVICES=sparkbot-v2
SPARKBOT_SERVICE_USE_SUDO=false
SPARKBOT_SERVER_COMMAND_TIMEOUT_SECONDS=20
SPARKBOT_SSH_ALLOWED_HOSTS=
SPARKBOT_SSH_ALLOWED_SERVICES=
SPARKBOT_SSH_CONNECT_TIMEOUT_SECONDS=10
SPARKBOT_SSH_COMMAND_TIMEOUT_SECONDS=30

# Sparkbot Directory
SPARKBOT_DIR=/app/sparkbot

# CORS Origins for chat backend
CORS_ORIGINS=*

# ===================
# WebSocket
# ===================
SPARKBOT_WS_URL=ws://127.0.0.1:8090

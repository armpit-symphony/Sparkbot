# Sparkbot Environment Variables Template
# Copy this file to .env and fill in the values

# ===================
# Frontend (React)
# ===================
REACT_APP_BACKEND_URL=https://remote.sparkpitlabs.com

# ===================
# Backend (FastAPI - sparkbot-v2)
# ===================
# Domain & Environment
DOMAIN=remote.sparkpitlabs.com
FRONTEND_HOST=https://remote.sparkpitlabs.com
ENVIRONMENT=production

# Project
PROJECT_NAME=Sparkbot
STACK_NAME=sparkbot

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# CORS (comma-separated origins)
BACKEND_CORS_ORIGINS=https://remote.sparkpitlabs.com,http://localhost,http://localhost:5173

# Database (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAILS_FROM_EMAIL=noreply@sparkpitlabs.com
EMAILS_FROM_NAME=Sparkbot
SMTP_TLS=True
SMTP_SSL=False

# First Superuser (admin account)
FIRST_SUPERUSER=admin@sparkpitlabs.com
FIRST_SUPERUSER_PASSWORD=your-admin-password

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# ===================
# Chat Backend (sparkbot-v1)
# ===================
# MongoDB (required)
MONGO_URL=mongodb://localhost:27017
DB_NAME=sparkbot

# JWT for chat authentication
CHAT_JWT_SECRET=your-chat-jwt-secret-change-in-production

# Dashboard access token
DASHBOARD_TOKEN=your-dashboard-token

# Sparkbot Service Key
SPARKBOT_SERVICE_KEY=your-service-key

# LLM API Keys (optional - at least one required for AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
Z01_API_KEY=
HF_API_KEY=
HUGGINGFACE_API_KEY=
EMERGENT_LLM_KEY=

# Google Workspace (optional - Gmail + Drive API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_GMAIL_USER=me
GOOGLE_DRIVE_SHARED_DRIVE_ID=

# Sparkbot Mode (balanced, fast, quality)
SPARKBOT_MODE=balanced

# Google Workspace (optional - Gmail + Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_GMAIL_USER=me
GOOGLE_DRIVE_SHARED_DRIVE_ID=

# Memory Guardian (optional)
SPARKBOT_MEMORY_GUARDIAN_ENABLED=true
SPARKBOT_MEMORY_GUARDIAN_DATA_DIR=
SPARKBOT_MEMORY_GUARDIAN_MAX_TOKENS=1200
SPARKBOT_MEMORY_GUARDIAN_RETRIEVE_LIMIT=6

# Token Guardian shadow routing (optional)
SPARKBOT_TOKEN_GUARDIAN_SHADOW_ENABLED=true
SPARKBOT_TOKEN_GUARDIAN_MODE=shadow              # off | shadow | live
SPARKBOT_TOKEN_GUARDIAN_LIVE_MODELS=             # optional comma-separated allowlist, e.g. gpt-4o-mini,claude-sonnet-4-5

# Telegram bridge (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_ENABLED=true
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_REQUIRE_PRIVATE_CHAT=true
TELEGRAM_POLL_TIMEOUT_SECONDS=45
TELEGRAM_POLL_RETRY_SECONDS=5

# Discord bridge (optional)
# 1. Create app at discord.com/developers → Bot → copy token
# 2. Enable "Message Content Intent" (privileged) in Bot settings
# 3. Invite bot with scopes: bot + applications.commands, permissions: Send Messages + Read Messages
DISCORD_BOT_TOKEN=
DISCORD_ENABLED=false
DISCORD_DM_ONLY=false               # true = DMs only, false = DMs + @mentions in guilds
DISCORD_GUILD_IDS=                  # comma-separated guild IDs to restrict to (optional)

# WhatsApp bridge (optional — requires Meta Business account + phone number)
# 1. developers.facebook.com → Create App → WhatsApp → Add Phone Number
# 2. System User → generate permanent token (whatsapp_business_messaging scope)
# 3. Set Webhook URL: https://yourdomain.com/whatsapp, Verify Token = WHATSAPP_VERIFY_TOKEN
# 4. Subscribe to: messages
# WARNING: registered phone cannot be used in personal WhatsApp simultaneously
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_ID=                  # numeric Phone Number ID from Meta portal
WHATSAPP_TOKEN=                     # permanent system user token
WHATSAPP_VERIFY_TOKEN=sparkbot-wa-verify   # must match what you set in Meta portal
WHATSAPP_APP_ID=                    # optional: for auto webhook registration
WHATSAPP_APP_SECRET=                # optional: for auto webhook registration
WHATSAPP_ALLOWED_PHONES=            # comma-separated E.164 numbers to allowlist (optional)
PUBLIC_URL=https://remote.sparkpitlabs.com  # your public HTTPS URL

# Executive / Task Guardian (optional)
SPARKBOT_EXECUTIVE_GUARDIAN_ENABLED=true
SPARKBOT_TASK_GUARDIAN_ENABLED=true
SPARKBOT_TASK_GUARDIAN_POLL_SECONDS=60
SPARKBOT_TASK_GUARDIAN_MAX_OUTPUT=2000
SPARKBOT_GUARDIAN_DATA_DIR=

# Voice — uses OPENAI_API_KEY
SPARKBOT_TTS_VOICE=alloy   # alloy | echo | fable | onyx | nova | shimmer
SPARKBOT_TTS_MODEL=tts-1   # tts-1 (fast) or tts-1-hd (higher quality)

# Server operations (optional)
SPARKBOT_ALLOWED_SERVICES=sparkbot-v2
SPARKBOT_SERVICE_USE_SUDO=false
SPARKBOT_SERVER_COMMAND_TIMEOUT_SECONDS=20
SPARKBOT_SSH_ALLOWED_HOSTS=
SPARKBOT_SSH_ALLOWED_SERVICES=
SPARKBOT_SSH_CONNECT_TIMEOUT_SECONDS=10
SPARKBOT_SSH_COMMAND_TIMEOUT_SECONDS=30

# Sparkbot Directory
SPARKBOT_DIR=/app/sparkbot

# Skills plugin directory (optional — path relative to backend/ or absolute)
SPARKBOT_SKILLS_DIR=skills

# CORS Origins for chat backend
CORS_ORIGINS=*

# ===================
# WebSocket
# ===================
SPARKBOT_WS_URL=ws://127.0.0.1:8090
